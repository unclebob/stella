{
  "name": "Run simulation",
  "scenarios": [
    {
      "name": "Stock flow transfers value between stocks",
      "steps": [
        {
          "keyword": "Given",
          "text": "a diagram model with stock Stock1 at 100 100"
        },
        {
          "keyword": "And",
          "text": "stock Stock2 at 300 200"
        },
        {
          "keyword": "And",
          "text": "flow Flow1 runs from stock Stock1 to stock Stock2"
        },
        {
          "keyword": "When",
          "text": "I set stock Stock1 initial value to 100"
        },
        {
          "keyword": "And",
          "text": "I set stock Stock2 initial value to 0"
        },
        {
          "keyword": "And",
          "text": "I set flow Flow1 rate to 10"
        },
        {
          "keyword": "And",
          "text": "I run the simulation for \u003csteps\u003e steps",
          "parameters": [
            "steps"
          ]
        },
        {
          "keyword": "Then",
          "text": "stock Stock1 value should be \u003cstock1\u003e",
          "parameters": [
            "stock1"
          ]
        },
        {
          "keyword": "And",
          "text": "stock Stock2 value should be \u003cstock2\u003e",
          "parameters": [
            "stock2"
          ]
        },
        {
          "keyword": "And",
          "text": "simulation time should be \u003ctime\u003e",
          "parameters": [
            "time"
          ]
        }
      ],
      "examples": [
        {
          "steps": "1",
          "stock1": "99",
          "stock2": "1",
          "time": "0.1"
        },
        {
          "steps": "5",
          "stock1": "95",
          "stock2": "5",
          "time": "0.5"
        }
      ]
    },
