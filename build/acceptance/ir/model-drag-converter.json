{
  "name": "Drag converter",
  "background": [
    {
      "keyword": "Given",
      "text": "converter Converter1 at 100 250"
    }
  ],
  "scenarios": [
    {
      "name": "Move converter to new position",
      "steps": [
        {
          "keyword": "When",
          "text": "I move converter Converter1 to \u003cx\u003e \u003cy\u003e",
          "parameters": [
            "x",
            "y"
          ]
        },
        {
          "keyword": "Then",
          "text": "converter Converter1 should be at position 220 300"
        },
        {
          "keyword": "And",
          "text": "converter Converter1 canvas position should be 220 300"
        }
      ],
      "examples": [
        {
          "x": "220",
          "y": "300"
        }
      ]
    },
    {
      "name": "Moving converter does not create another converter",
      "steps": [
        {
          "keyword": "When",
          "text": "I move converter Converter1 to 150 200"
        },
        {
          "keyword": "Then",
          "text": "the diagram converter count should be 1"
        },
        {
          "keyword": "And",
          "text": "the diagram should contain converter Converter1"
        }
      ],
      "examples": []
    },
    {
      "name": "Moving converter preserves connector endpoints",
      "steps": [
        {
          "keyword": "Given",
          "text": "a diagram model with stock Stock1 at 100 100"
        },
        {
          "keyword": "And",
          "text": "stock Stock2 at 300 200"
        },
        {
          "keyword": "And",
          "text": "flow Flow1 runs from stock Stock1 to stock Stock2"
        },
        {
          "keyword": "And",
          "text": "connector Connector1 runs from converter Converter1 to flow Flow1"
        },
        {
          "keyword": "When",
          "text": "I move converter Converter1 to 50 180"
        },
        {
          "keyword": "Then",
          "text": "converter Converter1 should be at position 50 180"
        },
        {
          "keyword": "And",
          "text": "connector Connector1 should run from converter Converter1 to flow Flow1"
        }
      ],
      "examples": []
    },
    {
      "name": "Move one converter without moving the other",
      "steps": [
        {
          "keyword": "Given",
          "text": "converter Converter2 at 300 250"
        },
        {
          "keyword": "When",
          "text": "I move converter \u003cname\u003e to \u003cx\u003e \u003cy\u003e",
          "parameters": [
            "name",
            "x",
            "y"
          ]
        },
        {
          "keyword": "Then",
          "text": "converter Converter1 should be at position 120 90"
        },
        {
          "keyword": "And",
          "text": "converter Converter2 should be at position 300 250"
        }
      ],
      "examples": [
        {
          "name": "Converter1",
          "x": "120",
          "y": "90"
        }
      ]
    }
  ]
}
