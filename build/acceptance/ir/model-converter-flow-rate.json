{
  "name": "Converter flow rate",
  "background": [
    {
      "keyword": "Given",
      "text": "a diagram model with stock Stock1 at 100 100"
    },
    {
      "keyword": "And",
      "text": "stock Stock2 at 300 200"
    },
    {
      "keyword": "And",
      "text": "flow Flow1 runs from stock Stock1 to stock Stock2"
    },
    {
      "keyword": "And",
      "text": "converter Converter1 at 100 250"
    },
    {
      "keyword": "And",
      "text": "connector Connector1 runs from converter Converter1 to flow Flow1"
    }
  ],
  "scenarios": [
    {
      "name": "Connected converter without formula shows zero",
      "steps": [
        {
          "keyword": "Then",
          "text": "converter Converter1 value should be 0"
        },
        {
          "keyword": "And",
          "text": "flow Flow1 rate should be 0"
        },
        {
          "keyword": "And",
          "text": "converter Converter1 canvas value should be 0"
        }
      ],
      "examples": []
    },
    {
      "name": "Constant formula sets converter value and flow rate",
      "steps": [
        {
          "keyword": "When",
          "text": "I set converter Converter1 formula to \u003cformula\u003e",
          "parameters": [
            "formula"
          ]
        },
        {
          "keyword": "Then",
          "text": "converter Converter1 value should be \u003cvalue\u003e",
          "parameters": [
            "value"
          ]
        },
        {
          "keyword": "And",
          "text": "flow Flow1 rate should be \u003cvalue\u003e",
          "parameters": [
            "value"
          ]
        },
        {
          "keyword": "And",
          "text": "converter Converter1 canvas value should be \u003cvalue\u003e",
          "parameters": [
            "value"
          ]
        }
      ],
      "examples": [
        {
          "formula": "5",
          "value": "5"
        }
      ]
    },
    {
      "name": "Connected stock named value scales in formula",
      "steps": [
        {
          "keyword": "Given",
          "text": "connector Connector2 runs from stock Stock1 to converter Converter1"
        },
        {
          "keyword": "When",
          "text": "I set stock Stock1 initial value to \u003cstock1\u003e",
          "parameters": [
            "stock1"
          ]
        },
        {
          "keyword": "And",
          "text": "I set converter Converter1 formula to \u003cformula\u003e",
          "parameters": [
            "formula"
          ]
        },
        {
          "keyword": "Then",
          "text": "converter Converter1 value should be \u003cvalue\u003e",
          "parameters": [
            "value"
          ]
        },
        {
          "keyword": "And",
          "text": "flow Flow1 rate should be \u003cvalue\u003e",
          "parameters": [
            "value"
          ]
        }
      ],
      "examples": [
        {
          "formula": "Stock1 * 0.1",
          "stock1": "100",
          "value": "10"
        },
        {
          "formula": "Stock1 * 0.1",
          "stock1": "50",
          "value": "5"
        }
      ]
    },
    {
      "name": "Two connected stocks sum in formula",
      "steps": [
        {
          "keyword": "Given",
          "text": "connector Connector2 runs from stock Stock1 to converter Converter1"
        },
        {
          "keyword": "And",
          "text": "connector Connector3 runs from stock Stock2 to converter Converter1"
        },
        {
          "keyword": "When",
          "text": "I set stock Stock1 initial value to \u003cstock1\u003e",
          "parameters": [
            "stock1"
          ]
        },
        {
          "keyword": "And",
          "text": "I set stock Stock2 initial value to \u003cstock2\u003e",
          "parameters": [
            "stock2"
          ]
        },
        {
          "keyword": "And",
          "text": "I set converter Converter1 formula to Stock1 + Stock2"
        },
        {
          "keyword": "Then",
          "text": "converter Converter1 value should be \u003cvalue\u003e",
          "parameters": [
            "value"
          ]
        },
        {
          "keyword": "And",
          "text": "flow Flow1 rate should be \u003cvalue\u003e",
          "parameters": [
            "value"
          ]
        }
      ],
      "examples": [
        {
          "stock1": "30",
          "stock2": "20",
          "value": "50"
        }
      ]
    },
    {
      "name": "Parentheses group operations in formula",
      "steps": [
        {
          "keyword": "Given",
          "text": "connector Connector2 runs from stock Stock1 to converter Converter1"
        },
        {
          "keyword": "And",
          "text": "connector Connector3 runs from stock Stock2 to converter Converter1"
        },
        {
          "keyword": "When",
          "text": "I set stock Stock1 initial value to \u003cstock1\u003e",
          "parameters": [
            "stock1"
          ]
        },
        {
          "keyword": "And",
          "text": "I set stock Stock2 initial value to \u003cstock2\u003e",
          "parameters": [
            "stock2"
          ]
        },
        {
          "keyword": "And",
          "text": "I set converter Converter1 formula to \u003cformula\u003e",
          "parameters": [
            "formula"
          ]
        },
        {
          "keyword": "Then",
          "text": "converter Converter1 value should be \u003cvalue\u003e",
          "parameters": [
            "value"
          ]
        },
        {
          "keyword": "And",
          "text": "flow Flow1 rate should be \u003cvalue\u003e",
          "parameters": [
            "value"
          ]
        }
      ],
      "examples": [
        {
          "formula": "(Stock1 + Stock2) * 0.1",
          "stock1": "100",
          "stock2": "50",
          "value": "15"
        },
        {
          "formula": "(Stock1 - Stock2) / 2",
          "stock1": "80",
          "stock2": "20",
          "value": "30"
        }
      ]
    },
    {
      "name": "Exponent and standard functions in formula",
      "steps": [
        {
          "keyword": "Given",
          "text": "connector Connector2 runs from stock Stock1 to converter Converter1"
        },
        {
          "keyword": "When",
          "text": "I set stock Stock1 initial value to \u003cstock1\u003e",
          "parameters": [
            "stock1"
          ]
        },
        {
          "keyword": "And",
          "text": "I set converter Converter1 formula to \u003cformula\u003e",
