    {
      "name": "Simulation transfers at computed constant rate",
      "steps": [
        {
          "keyword": "When",
          "text": "I set stock Stock1 initial value to 100"
        },
        {
          "keyword": "And",
          "text": "I set stock Stock2 initial value to 0"
        },
        {
          "keyword": "And",
          "text": "I set converter Converter1 formula to 10"
        },
        {
          "keyword": "And",
          "text": "I run the simulation for \u003csteps\u003e steps",
          "parameters": [
            "steps"
          ]
        },
        {
          "keyword": "Then",
          "text": "stock Stock1 value should be \u003cstock1\u003e",
          "parameters": [
            "stock1"
          ]
        },
        {
          "keyword": "And",
          "text": "stock Stock2 value should be \u003cstock2\u003e",
          "parameters": [
            "stock2"
          ]
        }
      ],
      "examples": [
        {
          "steps": "1",
          "stock1": "99",
          "stock2": "1"
        },
        {
          "steps": "5",
          "stock1": "95",
          "stock2": "5"
        }
      ]
    },
    {
