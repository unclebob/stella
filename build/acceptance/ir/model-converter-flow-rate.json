    {
      "name": "Reject invalid converter formula",
      "steps": [
        {
          "keyword": "When",
          "text": "I set converter Converter1 formula to \u003cformula\u003e",
          "parameters": [
            "formula"
          ]
        },
        {
          "keyword": "Then",
          "text": "the converter edit should be rejected"
        },
        {
          "keyword": "And",
          "text": "connector Connector1 should have no formula"
        }
      ],
      "examples": [
        {
          "formula": "Stock1 \u0026 0.1"
        },
        {
          "formula": "Missing * 2"
        },
        {
          "formula": "foo(1)"
        }
      ]
    },
    {
