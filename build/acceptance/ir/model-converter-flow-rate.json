{
  "name": "Converter flow rate",
  "background": [
    {
      "keyword": "Given",
      "text": "a diagram model with stock Stock1 at 100 100"
    },
    {
      "keyword": "And",
      "text": "stock Stock2 at 300 200"
    },
    {
      "keyword": "And",
      "text": "flow Flow1 runs from stock Stock1 to stock Stock2"
    },
    {
      "keyword": "And",
      "text": "converter Converter1 at 100 250"
    },
    {
      "keyword": "And",
      "text": "connector Connector1 runs from converter Converter1 to flow Flow1"
    }
  ],
  "scenarios": [
    {
      "name": "Connected converter without formula shows zero",
      "steps": [
        {
          "keyword": "Then",
          "text": "converter Converter1 value should be 0"
        },
        {
          "keyword": "And",
          "text": "flow Flow1 rate should be 0"
        },
        {
          "keyword": "And",
          "text": "converter Converter1 canvas value should be 0"
        }
      ],
      "examples": []
    },
    {
      "name": "Constant formula sets converter value and flow rate",
      "steps": [
        {
          "keyword": "When",
          "text": "I set converter Converter1 formula to \u003cformula\u003e",
          "parameters": [
            "formula"
          ]
        },
        {
          "keyword": "Then",
          "text": "converter Converter1 value should be \u003cvalue\u003e",
          "parameters": [
            "value"
          ]
        },
        {
          "keyword": "And",
          "text": "flow Flow1 rate should be \u003cvalue\u003e",
          "parameters": [
            "value"
          ]
        },
        {
          "keyword": "And",
          "text": "converter Converter1 canvas value should be \u003cvalue\u003e",
          "parameters": [
            "value"
          ]
        }
      ],
      "examples": [
        {
          "formula": "5",
          "value": "5"
        }
      ]
    },
    {
