    {
      "name": "Fractional formula uses rational literal",
      "steps": [
        {
          "keyword": "Given",
          "text": "connector Connector2 runs from stock Stock1 to converter Converter1"
        },
        {
          "keyword": "When",
          "text": "I set stock Stock1 initial value to 1"
        },
        {
          "keyword": "And",
          "text": "I set converter Converter1 formula to Stock1 * 1/2"
        },
        {
          "keyword": "Then",
          "text": "converter Converter1 value should be \u003cvalue\u003e",
          "parameters": [
            "value"
