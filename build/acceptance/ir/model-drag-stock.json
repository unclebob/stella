{
  "name": "Drag stock",
  "background": [
    {
      "keyword": "Given",
      "text": "a diagram model with stock Stock1 at 100 100"
    }
  ],
  "scenarios": [
    {
      "name": "Move stock to new position",
      "steps": [
        {
          "keyword": "When",
          "text": "I move stock Stock1 to \u003cx\u003e \u003cy\u003e",
          "parameters": [
            "x",
            "y"
          ]
        },
        {
          "keyword": "Then",
          "text": "stock Stock1 should be at position 250 180"
        },
        {
          "keyword": "And",
          "text": "stock Stock1 canvas position should be 250 180"
        }
      ],
      "examples": [
        {
          "x": "250",
          "y": "180"
        }
      ]
    },
    {
      "name": "Moving stock does not create another stock",
      "steps": [
        {
          "keyword": "When",
          "text": "I move stock Stock1 to 200 150"
        },
        {
          "keyword": "Then",
          "text": "the diagram stock count should be 1"
        },
        {
          "keyword": "And",
          "text": "the diagram should contain stock Stock1"
        }
      ],
      "examples": []
    },
    {
      "name": "Moving stock preserves flow endpoints",
      "steps": [
        {
          "keyword": "Given",
          "text": "a diagram model with stock Stock2 at 300 200"
        },
        {
          "keyword": "And",
          "text": "flow Flow1 runs from stock Stock1 to stock Stock2"
        },
        {
          "keyword": "When",
          "text": "I move stock Stock1 to 50 80"
        },
        {
          "keyword": "Then",
          "text": "stock Stock1 should be at position 50 80"
        },
        {
          "keyword": "And",
          "text": "flow Flow1 should run from stock Stock1 to stock Stock2"
        }
      ],
      "examples": []
    },
    {
      "name": "Move one stock without moving the other",
      "steps": [
        {
          "keyword": "Given",
          "text": "a diagram model with stock Stock2 at 300 200"
        },
        {
          "keyword": "When",
          "text": "I move stock \u003cname\u003e to \u003cx\u003e \u003cy\u003e",
          "parameters": [
            "name",
            "x",
            "y"
          ]
        },
        {
          "keyword": "Then",
          "text": "stock Stock1 should be at position 120 90"
        },
        {
          "keyword": "And",
          "text": "stock Stock2 should be at position 300 200"
        }
      ],
      "examples": [
        {
          "name": "Stock1",
          "x": "120",
          "y": "90"
        }
      ]
    }
  ]
