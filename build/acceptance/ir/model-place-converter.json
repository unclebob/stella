            "x",
            "y"
          ]
        },
        {
          "keyword": "Then",
          "text": "the diagram should contain converter Converter1"
        },
        {
          "keyword": "And",
          "text": "converter Converter1 should be at position 100 250"
        },
        {
          "keyword": "And",
          "text": "converter Converter1 value should be 0"
        }
      ],
      "examples": [
        {
          "x": "100",
          "y": "250"
        }
      ]
    },
    {
